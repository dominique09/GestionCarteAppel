{% extends 'base.html.twig' %}

{% block stylesheets %}
    <style>
        *{
            font-size: 12px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
    <div class="col-md-4">
        <div class="table-responsive">
            <table class="table table-sm table-hover table-striped">
                <thead class="thead-dark">
                <tr>
                    <th colspan="2">
                        Légende :
                        {% for type in typesEquipe %}
                            <span class="badge badge-{{ type.color }}">{{ type.name }}</span>
                        {% endfor %}
                    </th>
                    <th>
                        <a href="{{ path('equipe-create') }}" target="_blank" class="btn btn-success btn-sm btn-block">
                            Créer
                        </a>
                    </th>
                </tr>
                </thead>
                <tbody id="tableauEquipe">
                </tbody>
                <tfoot>
                    <tr><td colspan="3">
                            <span id="updatedAtEquipe"></span>
                        </td></tr>
                </tfoot>
            </table>
        </div>
    </div>
    <div class="col-md-8">
        <div class="table-responsive">
            <table class="table table-sm table-hover table-striped">
                <thead class="thead-light">
                    <tr>
                        <th>#Carte</th>
                        <th>Emplacement</th>
                        <th>Prio</th>
                        <th>Appelant</th>
                        <th>Assingations</th>
                        <th>
                            <a href="{{ path('carte-create') }}" class="btn btn-sm btn-success btn-block">
                                Ouvrir
                            </a>
                        </th>
                    </tr>
                </thead>
                <tbody id="tableauCarte">
                </tbody>
                <tfoot>
                <tr><td colspan="6">
                        <span id="updatedAtCarte"></span>
                    </td></tr>
                </tfoot>
            </table>
        </div>
    </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/repartition.js') }}"></script>
{% endblock %}